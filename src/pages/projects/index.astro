---
import PageLayout from '~/layouts/PageLayout.astro';
import Card from '~/components/static/Card.astro';
import Chip from '~/components/static/Chip.astro';
import FadeIn from '~/components/island/FadeIn.tsx';
import { getCollection } from 'astro:content';
import { ArrowUpRight } from 'lucide-react';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<PageLayout
  title="Projects"
  description="Selected engineering projects."
  eyebrow="Projects"
  heading="Things I've built"
  subtitle="A mix of production work, side projects, and experiments. The full list lives here."
>
  {
    projects.length === 0 ? (
      <p class="text-on-surface-variant">No projects yet.</p>
    ) : (
      <div class="grid gap-5 md:grid-cols-2">
        {projects.map((p, i) => (
          <FadeIn client:visible delay={i * 60}>
            <Card href={`/projects/${p.id}`} class="h-full">
              <div class="flex items-start justify-between gap-4">
                <h2 class="font-headline text-xl font-bold tracking-tight text-on-surface">
                  {p.data.title}
                </h2>
                <ArrowUpRight
                  size={18}
                  className="shrink-0 text-on-surface-variant transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-primary"
                />
              </div>
              <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-on-surface-variant">
                {p.data.role && <span>{p.data.role}</span>}
                {p.data.period && (
                  <>
                    <span class="text-outline">·</span>
                    <span class="font-mono tabular-nums">{p.data.period}</span>
                  </>
                )}
              </div>
              <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">
                {p.data.summary}
              </p>
              <div class="mt-5 flex flex-wrap gap-1.5">
                {p.data.stack.map((s) => (
                  <Chip>{s}</Chip>
                ))}
              </div>
            </Card>
          </FadeIn>
        ))}
      </div>
    )
  }
</PageLayout>
