---
import PageLayout from '~/layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
import { ArrowLeft, ArrowRight, Calendar, Tag as TagIcon } from 'lucide-react';
import GiscusComments from '~/components/static/GiscusComments.astro';
import { resolveLocale, localizePath } from '~/i18n/locale';
import { m } from '~/paraglide/messages.js';

const locale = resolveLocale(Astro.url.pathname);

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.lang === 'zh');
  return posts.map((p) => ({ params: { slug: p.id }, props: { post: p } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const date = post.data.publishedAt.toISOString().slice(0, 10);
const ogImage = `/og/${post.id}.png`;

const toc = headings.filter((h) => h.depth >= 2 && h.depth <= 3);

const siblings = (
  await getCollection(
    'blog',
    ({ data }) => !data.draft && data.lang === post.data.lang,
  )
).sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const idx = siblings.findIndex((p) => p.id === post.id);
const newer = idx > 0 ? siblings[idx - 1] : null;
const older = idx >= 0 && idx < siblings.length - 1 ? siblings[idx + 1] : null;
---

<PageLayout title={post.data.title} description={post.data.description} eyebrow="文章" ogImage={ogImage}>
  <div class="reading-progress" aria-hidden="true" data-reading-progress></div>

  <a href={localizePath('/blog', locale)} class="mb-6 inline-flex items-center gap-1.5 text-sm text-on-surface-variant hover:text-on-surface">
    <ArrowLeft size={14} /> {m.cta_back_all_posts({}, { locale })}
  </a>

  <header class="mb-12 max-w-3xl">
    <h1 class="font-headline text-4xl font-bold tracking-tighter md:text-5xl">
      {post.data.title}
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-on-surface-variant">
      {post.data.description}
    </p>

    <div class="mt-6 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-on-surface-variant">
      <span class="inline-flex items-center gap-1.5">
        <Calendar size={14} />
        <time datetime={post.data.publishedAt.toISOString()} class="font-mono tabular-nums">
          {date}
        </time>
      </span>
      <span class="rounded bg-surface px-1.5 py-0.5 font-mono text-xs uppercase">
        {post.data.lang}
      </span>
      {post.data.tags.length > 0 && (
        <span class="inline-flex items-center gap-1.5">
          <TagIcon size={14} />
          {post.data.tags.map((t) => (
            <span class="text-tertiary">#{t}</span>
          ))}
        </span>
      )}
    </div>
  </header>

  <div class="relative lg:flex lg:gap-10">
    <article class="prose prose-invert min-w-0 max-w-3xl flex-1 prose-headings:font-headline prose-headings:tracking-tight prose-a:text-primary prose-code:text-tertiary prose-pre:bg-transparent prose-pre:p-0">
      <Content />
    </article>

    {toc.length > 0 && (
      <aside class="hidden lg:block lg:w-56 lg:flex-shrink-0">
        <nav class="sticky top-24" aria-label={m.meta_on_this_page({}, { locale })}>
          <p class="mb-3 font-mono text-xs uppercase tracking-[0.18em] text-outline">
            {m.meta_on_this_page({}, { locale })}
          </p>
          <ul class="space-y-0.5 border-l border-outline-variant/60">
            {toc.map((h) => (
              <li>
                <a
                  href={`#${h.slug}`}
                  data-toc-link
                  class:list={[
                    'toc-link block border-l-2 border-transparent py-1 pr-2 text-[13px] leading-snug text-on-surface-variant transition-colors hover:text-on-surface',
                    h.depth === 2 ? 'pl-3' : 'pl-6',
                  ]}
                >
                  {h.text}
                </a>
              </li>
            ))}
          </ul>
        </nav>
      </aside>
    )}
  </div>

  {(older || newer) && (
    <nav class="mt-20 grid gap-4 border-t border-outline-variant/40 pt-10 md:grid-cols-2" aria-label="Post navigation">
      {older ? (
        <a
          href={localizePath(`/blog/${older.id}`, locale)}
          class="group flex items-start gap-3 rounded-2xl border border-outline-variant bg-surface-low/40 p-5 backdrop-blur-xl transition hover:border-[color:color-mix(in_oklab,var(--color-primary)_40%,transparent)] hover:bg-surface-high/40"
        >
          <ArrowLeft size={18} className="mt-0.5 shrink-0 text-on-surface-variant transition group-hover:-translate-x-0.5 group-hover:text-primary" />
          <div class="min-w-0">
            <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-outline">{m.meta_older_post({}, { locale })}</p>
            <p class="mt-1 truncate font-headline text-sm font-semibold text-on-surface group-hover:text-primary">
              {older.data.title}
            </p>
          </div>
        </a>
      ) : <div class="hidden md:block" />}
      {newer ? (
        <a
          href={localizePath(`/blog/${newer.id}`, locale)}
          class="group flex items-start justify-end gap-3 rounded-2xl border border-outline-variant bg-surface-low/40 p-5 text-right backdrop-blur-xl transition hover:border-[color:color-mix(in_oklab,var(--color-primary)_40%,transparent)] hover:bg-surface-high/40 md:col-start-2"
        >
          <div class="min-w-0">
            <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-outline">{m.meta_newer_post({}, { locale })}</p>
            <p class="mt-1 truncate font-headline text-sm font-semibold text-on-surface group-hover:text-primary">
              {newer.data.title}
            </p>
          </div>
          <ArrowRight size={18} className="mt-0.5 shrink-0 text-on-surface-variant transition group-hover:translate-x-0.5 group-hover:text-primary" />
        </a>
      ) : <div class="hidden md:block" />}
    </nav>
  )}

  <GiscusComments locale={locale} />
</PageLayout>

<script>
  function initBlogReader() {
    const bar = document.querySelector<HTMLElement>('[data-reading-progress]');
    if (bar) {
      const root = document.documentElement;
      const update = () => {
        const max = root.scrollHeight - root.clientHeight;
        const ratio = max > 0 ? root.scrollTop / max : 0;
        bar.style.setProperty('--progress', `${Math.min(100, Math.max(0, ratio * 100))}%`);
      };
      window.addEventListener('scroll', update, { passive: true });
      window.addEventListener('resize', update, { passive: true });
      update();
    }

    const links = Array.from(
      document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]'),
    );
    if (links.length === 0) return;
    const targets = links
      .map((a) => {
        const id = a.getAttribute('href')?.slice(1);
        return id ? document.getElementById(id) : null;
      })
      .filter((el): el is HTMLElement => !!el);

    if (targets.length === 0) return;

    const setActive = (id: string) => {
      for (const a of links) {
        a.classList.toggle('is-active', a.getAttribute('href') === `#${id}`);
      }
    };

    const visible = new Set<string>();
    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) visible.add(e.target.id);
          else visible.delete(e.target.id);
        }
        for (const t of targets) {
          if (visible.has(t.id)) {
            setActive(t.id);
            break;
          }
        }
      },
      { rootMargin: '-20% 0% -70% 0%' },
    );
    for (const t of targets) io.observe(t);
  }

  document.addEventListener('astro:page-load', initBlogReader);
</script>
