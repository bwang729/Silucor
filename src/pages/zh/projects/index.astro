---
import PageLayout from '~/layouts/PageLayout.astro';
import Card from '~/components/static/Card.astro';
import Chip from '~/components/static/Chip.astro';
import FadeIn from '~/components/island/FadeIn.tsx';
import { getCollection } from 'astro:content';
import { ArrowUpRight } from 'lucide-react';
import { m } from '~/paraglide/messages.js';
import { resolveLocale, localizePath } from '~/i18n/locale';

const locale = resolveLocale(Astro.url.pathname);
const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order,
);

const heading = locale === 'zh' ? '我做过的东西' : "Things I've built";
const subtitle =
  locale === 'zh'
    ? '生产项目、副业实验和原型的集合，完整列表在这里。'
    : 'A mix of production work, side projects, and experiments. The full list lives here.';
const empty = locale === 'zh' ? '暂无项目。' : 'No projects yet.';
---

<PageLayout
  title={m.nav_projects({}, { locale })}
  description={subtitle}
  eyebrow={m.nav_projects({}, { locale })}
  heading={heading}
  subtitle={subtitle}
>
  {
    projects.length === 0 ? (
      <p class="text-on-surface-variant">{empty}</p>
    ) : (
      <div class="grid gap-5 md:grid-cols-2">
        {projects.map((p, i) => (
          <FadeIn client:visible delay={i * 60}>
            <Card href={localizePath(`/projects/${p.id}`, locale)} class="h-full">
              <div class="flex items-start justify-between gap-4">
                <h2 class="font-headline text-xl font-bold tracking-tight text-on-surface">
                  {p.data.title}
                </h2>
                <ArrowUpRight
                  size={18}
                  className="shrink-0 text-on-surface-variant transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:text-primary"
                />
              </div>
              <div class="mt-1 flex flex-wrap items-center gap-x-3 gap-y-1 text-xs text-on-surface-variant">
                {p.data.role && <span>{p.data.role}</span>}
                {p.data.period && (
                  <>
                    <span class="text-outline">·</span>
                    <span class="font-mono tabular-nums">{p.data.period}</span>
                  </>
                )}
              </div>
              <p class="mt-3 text-sm leading-relaxed text-on-surface-variant">
                {p.data.summary}
              </p>
              <div class="mt-5 flex flex-wrap gap-1.5">
                {p.data.stack.map((s) => (
                  <Chip>{s}</Chip>
                ))}
              </div>
            </Card>
          </FadeIn>
        ))}
      </div>
    )
  }
</PageLayout>
