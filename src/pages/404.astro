---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Header from '~/components/static/Header.astro';
import Footer from '~/components/static/Footer.astro';
import { ArrowLeft, Compass } from 'lucide-react';
---

<BaseLayout title="Not found" description="404 — route not found.">
  <Header />
  <main class="container-page flex flex-1 items-center py-24">
    <div class="mx-auto max-w-xl text-center">
      <div
        class="mx-auto mb-8 grid size-16 place-items-center rounded-2xl bg-gradient-to-br from-[color:var(--color-primary)] to-[color:var(--color-primary-container)] text-[color:var(--color-on-primary)] shadow-xl shadow-[color:color-mix(in_oklab,var(--color-primary)_25%,transparent)]"
      >
        <Compass size={28} />
      </div>
      <p class="font-mono text-sm uppercase tracking-[0.2em] text-primary">404</p>
      <h1 class="mt-3 font-headline text-5xl font-bold tracking-tighter md:text-6xl">
        Lost in transit
      </h1>
      <p class="mt-4 text-on-surface-variant">
        The route you tried to reach doesn't exist — or hasn't been built yet. Let's head back.
      </p>
      <a
        href="/"
        class="mt-8 inline-flex items-center gap-2 rounded-full bg-gradient-to-br from-[color:var(--color-primary)] to-[color:var(--color-primary-container)] px-5 py-2.5 text-sm font-semibold text-[color:var(--color-on-primary)] shadow-lg transition hover:scale-[1.02] hover:brightness-110"
      >
        <ArrowLeft size={16} /> Back home
      </a>
    </div>
  </main>
  <Footer />
</BaseLayout>
