---
import '~/styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import CommandPalette from '~/components/island/CommandPalette.tsx';
import MagneticCursor from '~/components/island/MagneticCursor.tsx';
import { profile } from '~/data/profile';
import { resolveLocale } from '~/i18n/locale';
import { setLocale } from '~/paraglide/runtime.js';

interface Props {
  title?: string;
  description?: string;
  /** Override page-specific OG image path. */
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const locale = resolveLocale(Astro.url.pathname);
setLocale(locale, { reload: false });

const brand = locale === 'zh' ? '烁芯 Silucor' : profile.brand.en;
const tagline = locale === 'zh' ? profile.brand.tagline.zh : profile.brand.tagline.en;
const bio = locale === 'zh' ? profile.identity.bio.zh : profile.identity.bio.en;

const fullTitle = title ? `${title} · ${brand}` : `${brand} · ${tagline}`;
const desc = description ?? bio;
const og = ogImage ?? '/og-default.svg';
const canonical = new URL(Astro.url.pathname, Astro.site ?? profile.meta.origin).toString();
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-Hans' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonical} />

    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <meta name="author" content={profile.meta.author} />
    <meta name="theme-color" content="#0b1326" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={og} />
    <meta property="og:site_name" content={profile.brand.en} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={og} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />

    <ClientRouter />
    <slot name="head" />
  </head>
  <body class="relative flex min-h-dvh flex-col overflow-x-hidden">
    <div
      aria-hidden="true"
      class="glow-blob"
      style="top:-12rem;left:-8rem;width:32rem;height:32rem;background:#00a3ff"
    >
    </div>
    <div
      aria-hidden="true"
      class="glow-blob"
      style="bottom:-10rem;right:-8rem;width:28rem;height:28rem;background:#3cddc7"
    >
    </div>
    <slot />
    <CommandPalette client:load transition:persist />
    <MagneticCursor client:load transition:persist />
  </body>
</html>
