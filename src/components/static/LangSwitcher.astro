---
import { Languages } from 'lucide-react';
import { resolveLocale, localizePath } from '~/i18n/locale';
import { locales } from '~/paraglide/runtime.js';

const here = Astro.url.pathname;
const current = resolveLocale(here);
---

<div
  class="inline-flex items-center gap-0.5 rounded-full border border-outline-variant bg-surface-container-low/60 p-0.5"
  role="group"
  aria-label="Language"
>
  <Languages
    size={13}
    className="ml-2 mr-1 text-on-surface-variant"
    aria-hidden="true"
  />
  {
    locales.map((loc) => {
      const active = current === loc;
      const href = localizePath(here, loc);
      const label = loc === 'zh' ? '中' : 'EN';
      return (
        <a
          href={href}
          hreflang={loc === 'zh' ? 'zh-Hans' : 'en'}
          aria-current={active ? 'true' : undefined}
          class:list={[
            'rounded-full px-2.5 py-1 text-[11px] font-semibold tracking-wide transition-colors',
            active
              ? 'bg-[color:color-mix(in_oklab,var(--color-primary)_18%,transparent)] text-primary'
              : 'text-on-surface-variant hover:text-on-surface',
          ]}
        >
          {label}
        </a>
      );
    })
  }
</div>
