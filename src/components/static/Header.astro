---
import { Search } from 'lucide-react';
import { getNavLinks, isCurrentPath } from '~/lib/site';
import { profile } from '~/data/profile';
import { m } from '~/paraglide/messages.js';
import { resolveLocale, localizePath } from '~/i18n/locale';
import LangSwitcher from '~/components/static/LangSwitcher.astro';

const here = Astro.url.pathname;
const locale = resolveLocale(here);
const navLinks = getNavLinks(locale);
const brand = locale === 'zh' ? '烁芯 Silucor' : profile.brand.en;
---

<header
  transition:name="site-header"
  transition:animate="none"
  class="sticky top-0 z-40 border-b border-outline-variant/40 bg-[color:var(--color-background)]/60 backdrop-blur-xl"
>
  <div class="container-page flex h-16 items-center justify-between gap-6">
    <a href={localizePath('/', locale)} class="group flex items-center gap-2.5">
      <span
        class="grid size-9 place-items-center rounded-lg bg-gradient-to-br from-[color:var(--color-primary)] to-[color:var(--color-primary-container)] font-headline text-base font-bold text-[color:var(--color-on-primary)] shadow-lg shadow-[color:color-mix(in_oklab,var(--color-primary)_25%,transparent)] transition-transform group-hover:scale-105"
        aria-hidden="true"
      >
        S
      </span>
      <span class="font-headline text-base font-bold tracking-tight text-on-surface">
        {brand}
      </span>
    </a>

    <nav aria-label="Primary" class="hidden items-center gap-1 md:flex">
      {
        navLinks.map((l) => {
          const active = isCurrentPath(here, l.href);
          return (
            <a
              href={l.href}
              class:list={[
                'rounded-full px-3 py-1.5 text-sm font-medium transition-colors',
                active
                  ? 'bg-[color:color-mix(in_oklab,var(--color-primary)_15%,transparent)] text-primary'
                  : 'text-on-surface-variant hover:text-on-surface',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {l.label}
            </a>
          );
        })
      }
    </nav>

    <div class="hidden items-center gap-2 sm:flex">
      <LangSwitcher />
      <button
        type="button"
        data-cmdk-trigger
        aria-label={m.cta_command_palette({}, { locale })}
        class="inline-flex items-center gap-2 rounded-full border border-outline-variant px-3 py-1.5 text-xs text-on-surface-variant transition hover:border-[color:color-mix(in_oklab,var(--color-primary)_40%,transparent)] hover:text-on-surface"
      >
        <Search size={12} />
        <span class="hidden md:inline">{m.cta_command_palette({}, { locale })}</span>
        <kbd class="rounded border border-outline-variant bg-surface px-1 py-0.5 font-mono text-[10px] leading-none">
          ⌘K
        </kbd>
      </button>
      <a
        href={localizePath('/about', locale)}
        class="inline-flex items-center gap-1.5 rounded-full bg-gradient-to-br from-[color:var(--color-primary)] to-[color:var(--color-primary-container)] px-4 py-1.5 text-sm font-semibold text-[color:var(--color-on-primary)] shadow-md transition hover:brightness-110"
      >
        {m.nav_contact({}, { locale })}
      </a>
    </div>
  </div>

  <nav
    aria-label="Primary mobile"
    class="container-page flex flex-wrap gap-x-3 gap-y-1 border-t border-outline-variant/40 py-2 text-sm md:hidden"
  >
    {
      navLinks.map((l) => {
        const active = isCurrentPath(here, l.href);
        return (
          <a
            href={l.href}
            class:list={[
              'rounded-full px-2.5 py-1',
              active ? 'text-primary' : 'text-on-surface-variant hover:text-on-surface',
            ]}
            aria-current={active ? 'page' : undefined}
          >
            {l.label}
          </a>
        );
      })
    }
  </nav>
</header>
